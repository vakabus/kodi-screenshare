<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="script.kodi-screenshare-cec" name="Kodi Screenshare CEC" version="0.1.0" provider-name="Augment Code">
	<requires>
		<import addon="xbmc.python" version="3.0.0"/>
	</requires>
	<extension point="xbmc.python.script" library="script.py">
		<provides>executable</provides>
	</extension>
	<extension point="xbmc.addon.metadata">
		<summary lang="en">Wake the TV over HDMI-CEC for Kodi Screenshare</summary>
		<description lang="en">Executes Kodi HDMI-CEC built-ins through Addons.ExecuteAddon. Supported commands are activate, standby and toggle.</description>
		<platform>all</platform>
		<source>https://github.com/vakabus/kodi-screenshare</source>
	</extension>
</addon>